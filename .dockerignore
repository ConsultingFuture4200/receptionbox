# Build context excludes for the RunPod pod image.

# VCS / planning / docs — not needed at runtime.
.git
.gitignore
.github
.planning
docs
*.md
!README.md

# Heavy media. assets/manifest.csv and assets/scripts/ stay (referenced by
# tools/audit_pod_state.py and on-pod corpus regeneration). corpus_500 IS
# bundled (Plan 02-07) — needed for G1 smoke (5 calls). corpus_g711 IS
# bundled (2026-05-09 G2 sanity follow-up) — 6.8 MB at 8 kHz μ-law plus
# the 200 sibling .txt reference transcripts the G2 runner reads.
# corpus_hesitation stays excluded until G3 sanity needs it; render_env
# is operator-side only (Pitfall 1 — torch<=2.5.1 isolation).
# assets/corpus_500  (intentionally NOT excluded — see comment above)
# assets/corpus_g711 (intentionally NOT excluded — see comment above)
# corpus_hesitation re-included as of image v19: G3 turn-detection runs the
# full 51-clip corpus through the threshold sweep (plan 03-02 must_have).
# assets/corpus_hesitation
assets/render_env
assets/__pycache__

# Operator-only state.
results
secrets
audit
synthesis
derating

# Operator-side tests are not run on the pod.
tests

# Python cruft.
**/__pycache__
**/*.pyc
**/*.pyo
.venv
.mypy_cache
.pytest_cache
.ruff_cache

# Editor / OS noise.
.idea
.vscode
.DS_Store
